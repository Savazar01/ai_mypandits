// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// This is the correct Prisma 7 generator block
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  role     Role    @default(CUSTOMER)
  whatsapp String? @unique

  // BetterAuth Admin Plugin Fields
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  // This is where all role-specific data (Services, Skills, Bio) lives
  profile_data Json? @default("{}")

  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  catalogItems  CatalogItem[]
  events        Event[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model CatalogItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  price       Float?
  priceUnit   String?
  description String?
  category    String?
  currency    String?
  createdAt   DateTime @default(now())

  @@map("catalog_item")
}

model Event {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id            String
  owner               User               @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  title               String
  description         String?
  event_type          String
  start_date          DateTime?
  end_date            DateTime?
  status              String             @default("Draft")
  location            String?
  orchestration_state Json?              @default("{}")
  created_at          DateTime           @default(now())
  updated_at          DateTime           @default(now())
  days                EventDay[]
  activities          Activity[]
  invitations         Invitation[]
  logs                OrchestrationLog[]

  @@map("events")
}

model EventDay {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id        String     @db.Uuid
  event           Event      @relation(fields: [event_id], references: [id], onDelete: Cascade)
  date            DateTime   @db.Date
  sequence_number Int
  created_at      DateTime   @default(now())
  activities      Activity[]

  @@map("event_days")
}

model Activity {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  day_id          String       @db.Uuid
  day             EventDay     @relation(fields: [day_id], references: [id], onDelete: Cascade)
  event_id        String       @db.Uuid
  event           Event        @relation(fields: [event_id], references: [id], onDelete: Cascade)
  title           String
  start_time      DateTime
  end_time        DateTime
  location_type   String       @default("Physical")
  location        String?
  status          String       @default("Pending")
  is_orchestrated Boolean      @default(false)
  created_at      DateTime     @default(now())
  invitations     Invitation[]

  @@map("activities")
}

model Invitation {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id        String    @db.Uuid
  event           Event     @relation(fields: [event_id], references: [id], onDelete: Cascade)
  activity_id     String?   @db.Uuid
  activity        Activity? @relation(fields: [activity_id], references: [id], onDelete: SetNull)
  invitee_name    String
  invitee_email   String?
  whatsapp_number String
  num_guests      Int       @default(1)
  rsvp_status     String    @default("Pending")
  invite_sent     Boolean   @default(false)
  access_token    String    @unique @default(dbgenerated("md5(random()::text)"))
  created_at      DateTime  @default(now())

  @@map("invitations")
}

model OrchestrationLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id    String   @db.Uuid
  event       Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  agent_name  String
  log_message String
  timestamp   DateTime @default(now())

  @@map("orchestration_logs")
}
